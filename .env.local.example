# Website's own Supabase (currently unused — empty public schema, reserved for future)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# PostHog — conversion analytics + session replay
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Post-deploy SEO verification strings
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=

# Cross-codebase bridge — idigdata-app Supabase (CRM target for /api/contact)
# The website POSTs leads here; idigdata-app's classify-extract-route pipeline picks them up.
IDIGDATA_APP_SUPABASE_URL=
IDIGDATA_APP_SUPABASE_ANON_KEY=

# Resend — transactional email for contact-form notifications.
# Free tier = 3000 emails/month. Key from https://resend.com/api-keys (starts with re_)
RESEND_API_KEY=
EMAIL_NOTIFY_TO=
